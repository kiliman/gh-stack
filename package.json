{
  "name": "gh-stack",
  "version": "0.1.0",
  "description": "Stacked PR manager for squash-merge workflows",
  "author": "Kiliman <kiliman@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kiliman/gh-stack"
  },
  "keywords": ["git", "github", "stacked-prs", "squash-merge", "cli"],
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "gh-stack": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile src/index.ts --outfile dist/gh-stack",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun test"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "picocolors": "^1.1.1"
  }
}
